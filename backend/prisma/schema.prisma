generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CITIZEN
  AUTHORITY
  ADMIN
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum ViolationType {
  NO_HELMET
  TRIPLE_RIDING
  SIGNAL_VIOLATION
  ILLEGAL_PARKING
  WRONG_ROUTE
  OVER_SPEEDING
}

enum WithdrawStatus {
  PENDING
  PROCESSED
  FAILED
}

model User {
  id            String       @id @default(uuid())
  phone         String       @unique
  name          String?
  role          Role         @default(CITIZEN)
  isVerified    Boolean      @default(false)
  isActive      Boolean      @default(true)
  pointsBalance Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  reports       Report[]
  rewards       Reward[]
  withdrawals   Withdrawal[]
  reviewedBy    Report[]     @relation("ReviewedBy")

  @@index([phone])
}

model Report {
  id            String        @id @default(uuid())
  reporterId    String
  reporter      User          @relation(fields: [reporterId], references: [id])
  violationType ViolationType
  description   String?
  vehiclePlate  String?
  latitude      Float
  longitude     Float
  address       String?
  city          String?
  photoUrls     String[]
  videoUrl      String?
  thumbnailUrl  String?
  status        ReportStatus  @default(PENDING)
  reviewerId    String?
  reviewer      User?         @relation("ReviewedBy", fields: [reviewerId], references: [id])
  reviewedAt    DateTime?
  reviewNotes   String?
  challanNumber String?
  pointsAwarded Int?
  isAnonymous   Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  rewards       Reward[]

  @@index([reporterId])
  @@index([status])
  @@index([latitude, longitude])
}

model Reward {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id])
  points    Int
  rupees    Float
  createdAt DateTime @default(now())

  @@index([userId])
}

model Withdrawal {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  amount        Float
  upiId         String
  status        WithdrawStatus @default(PENDING)
  razorpayPayId String?
  createdAt     DateTime       @default(now())
  processedAt   DateTime?

  @@index([userId])
}